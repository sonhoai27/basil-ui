      "props": [
        { "name": "type", "type": "string", "required": false, "description": "Native input type." },
        { "name": "disabled", "type": "boolean", "required": false, "description": "Disable the field." },
        { "name": "aria-invalid", "type": "boolean", "required": false, "description": "Render the destructive error border." }
      ]
    },
    {
      "name": "Textarea",
      "category": "form",
      "source": "src/components/ui/textarea.tsx",
      "story": "src/stories/forms.stories.tsx",
