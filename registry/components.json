{
  "$schema": "https://basil-ui.dev/registry.schema.json",
  "name": "basil-ui",
  "version": "0.1.0",
  "components": [
    {
      "name": "Button",
      "category": "primitive",
      "source": "src/components/domain/button.tsx",
      "story": "src/stories/buttons-badges.stories.tsx",
      "description": "Thin ergonomic wrapper over the base button, adding loading state and leading/trailing icon slots.",
      "props": [
        { "name": "variant", "type": "'default' | 'destructive' | 'outline' | 'secondary' | 'ghost' | 'link'", "required": false, "description": "Visual style." },
        { "name": "size", "type": "'default' | 'sm' | 'lg' | 'icon' | 'icon-sm'", "required": false, "description": "Control size." },
        { "name": "isLoading", "type": "boolean", "required": false, "description": "Shows a spinner, disables the button, and sets aria-busy." },
        { "name": "leadingIcon", "type": "React.ReactNode", "required": false, "description": "Icon rendered before the label." },
        { "name": "trailingIcon", "type": "React.ReactNode", "required": false, "description": "Icon rendered after the label." },
        { "name": "fullWidth", "type": "boolean", "required": false, "description": "Stretch to the container width." }
      ],
      "variants": {
        "variant": ["default", "destructive", "outline", "secondary", "ghost", "link"],
        "size": ["default", "sm", "lg", "icon", "icon-sm"]
      }
    },
    {
      "name": "Badge",
      "category": "primitive",
      "source": "src/components/ui/badge.tsx",
      "story": "src/stories/buttons-badges.stories.tsx",
      "description": "Small pill label with solid and borderless tinted (soft) status variants.",
      "props": [
        { "name": "variant", "type": "'default' | 'secondary' | 'destructive' | 'outline' | 'caption' | 'soft-primary' | 'soft-success' | 'soft-warning' | 'soft-info' | 'soft-muted' | 'soft-destructive'", "required": false, "description": "Solid or borderless tinted style." },
        { "name": "size", "type": "'default' | 'sm'", "required": false, "description": "Pill size." }
      ],
      "variants": {
        "variant": ["default", "secondary", "destructive", "outline", "caption", "soft-primary", "soft-success", "soft-warning", "soft-info", "soft-muted", "soft-destructive"],
        "size": ["default", "sm"]
      }
    },
    {
      "name": "StatusPill",
      "category": "domain",
      "source": "src/components/domain/status-pill.tsx",
      "story": "src/stories/buttons-badges.stories.tsx",
      "description": "Opinionated order-lifecycle status pill: a colored dot plus label mapped from a status key.",
      "props": [
        { "name": "status", "type": "'pending_payment' | 'paid' | 'packing' | 'sent' | 'cancelled'", "required": true, "description": "Lifecycle state; maps to a soft Badge variant, dot color, and label." }
      ]
    },
    {
      "name": "Input",
      "category": "form",
