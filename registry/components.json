      "props": [
        { "name": "items", "type": "MultiSelectItem[]", "required": true, "description": "Selectable options ({ value, label, description?, icon?, disabled? })." },
        { "name": "value", "type": "string[]", "required": true, "description": "Array of selected values." },
        { "name": "onChange", "type": "(value: string[]) => void", "required": true, "description": "Selection change handler." },
