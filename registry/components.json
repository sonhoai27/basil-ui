      ],
      "dependencies": ["cmdk", "@radix-ui/react-popover"]
    },
    {
      "name": "CurrencyInput",
      "category": "form",
      "source": "src/components/domain/currency-input.tsx",
      "story": "src/stories/data-entry.stories.tsx",
      "description": "Money field with thousands grouping on blur that emits a raw integer and reserves space for a currency suffix.",
      "props": [
        { "name": "value", "type": "number", "required": false, "description": "Raw integer amount (no decimals)." },
        { "name": "onChange", "type": "(value?: number) => void", "required": true, "description": "Emits the raw integer; undefined when empty." },
        { "name": "min", "type": "number", "required": false, "description": "Lower bound clamped on blur." },
        { "name": "suffix", "type": "string", "required": false, "description": "Trailing adornment inside the field (defaults to the currency symbol)." }
      ]
    },
    {
      "name": "NumberField",
      "category": "form",
      "source": "src/components/domain/currency-input.tsx",
      "story": "src/stories/data-entry.stories.tsx",
      "description": "Integer entry with optional minus/plus steppers that clamps to [min, max] and emits a raw integer.",
