        { "name": "value", "type": "number", "required": false, "description": "Current integer value." },
        { "name": "onChange", "type": "(value?: number) => void", "required": true, "description": "Emits the raw integer." },
        { "name": "min", "type": "number", "required": false, "description": "Lower bound." },
        { "name": "max", "type": "number", "required": false, "description": "Upper bound." },
        { "name": "step", "type": "number", "required": false, "description": "Increment applied by the steppers (default 1)." },
        { "name": "steppers", "type": "boolean", "required": false, "description": "Render flanking minus/plus buttons." },
        { "name": "suffix", "type": "string", "required": false, "description": "Trailing unit adornment, e.g. 'kg'." }
      ]
    },
    {
      "name": "QuantityStepper",
      "category": "form",
      "source": "src/components/domain/quantity-stepper.tsx",
      "story": "src/stories/data-entry.stories.tsx",
