        { "name": "onValueChange", "type": "(value: string) => void", "required": false, "description": "Selection change handler (on Select root)." },
        { "name": "disabled", "type": "boolean", "required": false, "description": "Disable the control." }
      ],
      "dependencies": ["@radix-ui/react-select"]
    },
    {
